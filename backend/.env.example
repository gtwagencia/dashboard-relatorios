# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/meta_ads_db
DATABASE_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars

# ── Encryption ────────────────────────────────────────────────────────────────
# 64-char hex string = 32 bytes for AES-256
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string_for_aes256_encryption_key_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Scheduler ─────────────────────────────────────────────────────────────────
DISABLE_SCHEDULER=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
