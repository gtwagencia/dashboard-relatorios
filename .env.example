# ============================================================
# Meta Ads Dashboard - Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=metaads
POSTGRES_USER=metaads
POSTGRES_PASSWORD=SUA_SENHA_FORTE_AQUI

# --- Redis ---
REDIS_PASSWORD=SUA_SENHA_REDIS_AQUI

# --- JWT (gere com: openssl rand -hex 64) ---
JWT_SECRET=gere_com_openssl_rand_hex_64
JWT_REFRESH_SECRET=gere_com_openssl_rand_hex_64_diferente

# --- Criptografia de Tokens Meta (gere com: openssl rand -hex 32) ---
TOKEN_ENCRYPTION_KEY=gere_com_openssl_rand_hex_32

# --- Meta Ads API ---
# Crie um app em: https://developers.facebook.com/apps/
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# --- OpenAI (para sugestões de IA) ---
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- n8n Webhook Base URL ---
# URL base do seu n8n (ex: https://n8n.seudominio.com)
N8N_WEBHOOK_BASE_URL=https://n8n.seudominio.com

# --- Frontend ---
# URL da API acessível pelo navegador (em produção, usa /api via nginx)
NEXT_PUBLIC_API_URL=/api

# --- Nginx ---
HTTP_PORT=80
CORS_ORIGIN=http://localhost

# ============================================================
# COMO OBTER O TOKEN DO META ADS:
# 1. Acesse: https://developers.facebook.com/tools/explorer/
# 2. Selecione seu App
# 3. Adicione as permissões: ads_read, ads_management, business_management
# 4. Clique em "Gerar Token de Acesso"
# 5. Para token de longa duração (60 dias), use:
#    GET https://graph.facebook.com/oauth/access_token
#      ?grant_type=fb_exchange_token
#      &client_id={APP_ID}
#      &client_secret={APP_SECRET}
#      &fb_exchange_token={SHORT_LIVED_TOKEN}
# ============================================================

# ============================================================
# SENHA ADMIN PADRÃO:
# Email: admin@dashboard.com
# Senha: Admin@123 (ALTERE IMEDIATAMENTE após o primeiro login)
# Para alterar, acesse /api/admin/clients e atualize via API
# ============================================================
