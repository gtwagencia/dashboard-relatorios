# ============================================================
# Meta Ads Dashboard — Variáveis de Ambiente (Swarm/Portainer)
# Configure estas variáveis no painel do Portainer ao criar a stack
# ============================================================

# --- Domínio ---
DOMAIN=dashboard.gtw.digital

# --- Banco de dados (PostgreSQL existente no Swarm) ---
# Formato: postgresql://usuario:senha@host:5432/banco
# O host é o nome do serviço Swarm do postgres (ex: postgres_postgres)
# ATENÇÃO: Se a senha tiver o caractere @, substitua por %40 na URL
DATABASE_URL=postgresql://usuario:senha@nome_servico_postgres:5432/dashboardads

# --- Redis (Redis existente no Swarm) ---
# O host é o nome do serviço Swarm do redis (ex: redis_redis)
REDIS_URL=redis://:senha_redis@nome_servico_redis:6379

# --- JWT (já gerados) ---
JWT_SECRET=gere_com_openssl_rand_hex_64
JWT_REFRESH_SECRET=gere_com_openssl_rand_hex_64_diferente
TOKEN_ENCRYPTION_KEY=gere_com_openssl_rand_hex_32

# --- Meta Ads API ---
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
META_ACCESS_TOKEN=seu_token_universal_aqui

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- n8n ---
N8N_WEBHOOK_BASE_URL=https://auto.gtw.digital

# ============================================================
# COMO DESCOBRIR O HOST DO POSTGRES E REDIS NO SWARM:
#
# No terminal SSH do servidor, execute:
#   docker service ls
#
# O nome que aparece na coluna NAME é o hostname a usar.
# Exemplos comuns: postgres_postgres, redis_redis, infra_db
#
# Para testar a conexão após o deploy:
#   docker exec $(docker ps -q -f name=metaads-backend) \
#     node -e "require('pg').Pool && new (require('pg').Pool)({connectionString:process.env.DATABASE_URL}).query('SELECT 1').then(()=>console.log('DB OK')).catch(e=>console.error(e.message))"
# ============================================================

# ============================================================
# COMO FAZER O DEPLOY NO PORTAINER (SWARM):
#
# 1. SSH no servidor e clone/atualize o repositório:
#    git clone https://github.com/SEU_USUARIO/SEU_REPO.git /opt/metaads
#    cd /opt/metaads
#
# 2. Builde as imagens Docker no servidor:
#    docker build -t metaads-backend:latest ./backend
#    docker build -t metaads-frontend:latest ./frontend
#
# 3. No Portainer → Stacks → Add Stack:
#    - Nome: metaads
#    - Upload o docker-compose.yml
#    - Em "Environment variables", adicione todas as variáveis acima
#    - Deploy the stack
#
# 4. Crie o usuário admin (somente na primeira vez):
#    docker exec $(docker ps -q -f name=metaads_metaads-backend) \
#      node scripts/setup-admin.js
#
# 5. Acesse: https://dashboard.gtw.digital
# ============================================================
